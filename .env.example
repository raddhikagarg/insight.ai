# Set these as Environment Variables in the Vercel dashboard for your
# API project (Project -> Settings -> Environment Variables), not as a
# committed .env file.

# --- Database (REQUIRED on Vercel — filesystem is ephemeral, SQLite won't persist) ---
# Neon example: postgresql+psycopg2://user:password@ep-xxxx.neon.tech/insightai?sslmode=require
# Supabase example: postgresql+psycopg2://postgres:password@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg2://neondb_owner:npg_ear6XnJmh8wo@ep-weathered-wave-au96x77i-pooler.c-10.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# --- Gemini LLM (optional) ---
# Leave blank to run entirely on the built-in rule-based NL->SQL + insights engine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- CORS ---
# Comma-separated list of allowed frontend origins, e.g. your Vercel web URL.
ALLOWED_ORIGINS=https://insightai-web.vercel.app

